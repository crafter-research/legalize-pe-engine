# --- Database (Turso / libSQL) ---
# Leave both unset to use a local SQLite file (file:./local.db) for development.
# For production, create a Turso DB: https://turso.tech
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Git history endpoints (/history, /diff, /at, /compare) ---
# These read the public corpus over the GitHub API (no local clone needed).
# A token is optional but raises the rate limit from 60 to 5,000 req/hour.
GITHUB_TOKEN=

# --- Corpus import script (bun run db:import) only ---
# Path to a local clone of the corpus repo (crafter-research/legalize-pe).
# Defaults to ../../../../legalize-pe relative to the script if unset.
LEGALIZE_PE_CORPUS=
