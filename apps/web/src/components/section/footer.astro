---
const year = new Date().getFullYear();
---

<footer class="border-t border-border/60 bg-card/40 mt-auto">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-8">
    <div class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
      <div class="space-y-2 max-w-md">
        <div class="flex items-center gap-2">
          <span class="flex size-6 items-center justify-center rounded-md bg-primary text-primary-foreground text-base leading-none">L</span>
          <span class="text-base leading-none tracking-tight">Legalize<span class="text-muted-foreground">.pe</span></span>
        </div>
        <p class="text-sm text-muted-foreground leading-relaxed" data-i18n="footer.tagline">
          Peruvian legislation as a git repository. Every law a file, every reform a commit.
          Community-maintained by <a href="https://github.com/crafter-research" class="rounded-sm underline underline-offset-4 transition-colors hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">Crafter Research</a>.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-x-12 gap-y-2 text-sm">
        <div class="space-y-1.5">
          <p class="font-medium text-foreground" data-i18n="footer.browse">Browse</p>
          <a href="/laws" class="block w-fit rounded-sm text-muted-foreground transition-colors hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" data-i18n="nav.laws">Laws</a>
          <a href="/regions" class="block w-fit rounded-sm text-muted-foreground transition-colors hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" data-i18n="nav.regions">Regions</a>
          <a href="/audit" class="block w-fit rounded-sm text-muted-foreground transition-colors hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" data-i18n="nav.audit">Audit</a>
        </div>
        <div class="space-y-1.5">
          <p class="font-medium text-foreground" data-i18n="footer.build">Build</p>
          <a href="/api" class="block w-fit rounded-sm text-muted-foreground transition-colors hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" data-i18n="nav.api">API</a>
          <a href="/feed.xml" class="block w-fit rounded-sm text-muted-foreground transition-colors hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">RSS</a>
          <a href="https://github.com/crafter-research/legalize-pe" class="block w-fit rounded-sm text-muted-foreground transition-colors hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">GitHub</a>
        </div>
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-border/60 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2 text-xs text-muted-foreground">
      <p>
        <span data-i18n="footer.legal">Content: public domain (DLeg 822 Art. 9). Code: MIT.</span> © {year} Crafter Research.
      </p>
      <p data-i18n="footer.federation">
        Part of the <a href="https://legalize.dev" class="rounded-sm underline underline-offset-4 transition-colors hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">legalize.dev</a> federation.
      </p>
    </div>
  </div>
</footer>
