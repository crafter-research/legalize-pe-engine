---
import { CommandPaletteTrigger } from "@/components/island/command-palette-trigger";
import { LanguageToggle } from "@/components/island/language-toggle";
import { ThemeToggle } from "@/components/island/theme-toggle";

const navItems = [
  { href: "/laws", label: "Laws", key: "nav.laws" },
  { href: "/regions", label: "Regions", key: "nav.regions" },
  { href: "/audit", label: "Audit", key: "nav.audit" },
  { href: "/api", label: "API", key: "nav.api" },
  { href: "/about", label: "About", key: "nav.about" },
];

const pathname = Astro.url.pathname;
---

<header class="sticky top-0 z-40 w-full border-b border-border/60 bg-background/85 backdrop-blur supports-[backdrop-filter]:bg-background/70">
  <div class="mx-auto flex h-14 max-w-6xl items-center gap-4 px-4 sm:px-6">
    <a
      href="/"
      class="flex items-center gap-2 shrink-0 rounded-md transition-opacity hover:opacity-80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
      aria-label="Legalize PE home"
    >
      <span
        class="flex size-7 items-center justify-center rounded-md bg-primary text-primary-foreground text-lg leading-none"
      >
        L
      </span>
      <span class="text-lg leading-none tracking-tight">
        Legalize<span class="text-muted-foreground">.pe</span>
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
      {navItems.map(({ href, label, key }) => {
        const active = pathname === href || pathname.startsWith(`${href}/`);
        return (
          <a
            href={href}
            data-i18n={key}
            class:list={[
              "rounded-md px-3 py-1.5 text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring",
              active
                ? "bg-accent text-accent-foreground"
                : "text-muted-foreground hover:text-foreground hover:bg-accent/60",
            ]}
            aria-current={active ? "page" : undefined}
          >
            {label}
          </a>
        );
      })}
    </nav>

    <div class="flex-1" />

    <div class="flex items-center gap-1">
      <CommandPaletteTrigger client:load />
      <LanguageToggle client:load />
      <ThemeToggle client:load />
    </div>
  </div>
</header>
