---
import { pwaInfo } from "virtual:pwa-info";
import Analytics from "@vercel/analytics/astro";
import "@/styles/globals.css";

import ThemeScript from "@/components/island/theme-script.astro";
import Footer from "@/components/section/footer.astro";
import Header from "@/components/section/header.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noHeader?: boolean;
}

const {
  title,
  description = "Peruvian legislation as a git repository. Every law a file, every reform a commit.",
  ogImage,
  noHeader = false,
} = Astro.props;

const siteUrl = Astro.url.origin;
const defaultOgImage = `${siteUrl}/api/og/index`;
const finalOgImage = ogImage || defaultOgImage;
const fullTitle = title.includes("Legalize PE") ? title : `${title} · Legalize PE`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <ThemeScript />

    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#fafaf9" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#211f1c" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Legalize PE" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <link rel="mask-icon" href="/favicon.svg" color="#000000" />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={finalOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={finalOgImage} />

    <link rel="canonical" href={Astro.url.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Legalize PE — RSS" href="/feed.xml" />
    <title>{fullTitle}</title>

    {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:rounded-md focus:bg-primary focus:px-3 focus:py-2 focus:text-sm focus:text-primary-foreground">
      Skip to content
    </a>

    {!noHeader && <Header />}

    <main id="main" class="flex-1">
      <slot />
    </main>

    <Footer />

    <script>
      import { registerSW } from "virtual:pwa-register";
      registerSW({ immediate: true });
    </script>

    <Analytics />
  </body>
</html>
