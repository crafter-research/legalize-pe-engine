---
import { readFileSync } from "node:fs";
import { join } from "node:path";
import { Badge } from "@/components/ui/badge";
import {
  Empty,
  EmptyDescription,
  EmptyHeader,
  EmptyMedia,
  EmptyTitle,
} from "@/components/ui/empty";
import Layout from "@/layouts/Layout.astro";
import {
  collectAllNormFiles,
  jurisdictionLabels,
  normUniqueId,
  parseFrontmatter,
} from "@/lib/laws";
import { ArrowRightIcon, FilterIcon, SearchIcon } from "lucide-react";

type Norm = {
  identifier: string;
  id: string;
  title: string;
  rank: string;
  publication_date: string;
  jurisdiction: string;
  status: string;
};

const norms: Norm[] = [];
for (const { absDir, relativePath } of collectAllNormFiles()) {
  try {
    const raw = readFileSync(join(absDir, relativePath), "utf-8");
    const { meta } = parseFrontmatter(raw);
    if (!meta.title || !meta.identifier) continue;
    norms.push({
      identifier: meta.identifier,
      id: normUniqueId(`${absDir.split("/").pop() ?? ""}/${relativePath}`),
      title: meta.title,
      rank: meta.rank ?? "",
      publication_date: meta.publication_date ?? "",
      jurisdiction: meta.jurisdiction ?? "pe",
      status: meta.status ?? "in_force",
    });
  } catch {
    /* skip */
  }
}
norms.sort((a, b) => (b.publication_date ?? "").localeCompare(a.publication_date ?? ""));

// Show top 50 by date initially; cmd+k is the real search UX
const PAGE_SIZE = 50;
const initial = norms.slice(0, PAGE_SIZE);

const total = norms.length;
const rankCounts: Record<string, number> = {};
for (const n of norms) rankCounts[n.rank] = (rankCounts[n.rank] ?? 0) + 1;

const RANK_LABELS_EN: Record<string, string> = {
  constitucion: "Constitution",
  ley: "Law",
  decreto_legislativo: "Legislative Decree",
  decreto_supremo: "Supreme Decree",
  decreto_de_urgencia: "Urgency Decree",
  decreto_urgencia: "Urgency Decree",
  decreto_ley: "Decree Law",
  resolucion_legislativa: "Legislative Resolution",
  resolucion_ministerial: "Ministerial Resolution",
  resolucion_suprema: "Supreme Resolution",
  ley_de_reforma_constitucional: "Constitutional Reform",
  ordenanza_regional: "Regional Ordinance",
  ordenanza_municipal: "Municipal Ordinance",
  decreto_regional: "Regional Decree",
  acuerdo_regional: "Regional Agreement",
  acuerdo_de_concejo: "Council Agreement",
  decreto_de_alcaldia: "Mayoral Decree",
};

const STATUS_LABELS: Record<string, { label: string; cls: string }> = {
  in_force: { label: "In force", cls: "text-status-in-force" },
  repealed: { label: "Repealed", cls: "text-status-repealed" },
  partially_repealed: { label: "Partially repealed", cls: "text-status-partial" },
  annulled: { label: "Annulled", cls: "text-status-repealed" },
  expired: { label: "Expired", cls: "text-muted-foreground" },
};
---

<Layout title="Laws · Legalize PE" description={`Browse ${total.toLocaleString()} Peruvian legal norms. Filter by rank, jurisdiction, status, or search by title.`}>
  <section class="border-b border-border/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-12 lg:py-16">
      <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-sm font-medium text-primary uppercase tracking-widest mb-3" data-i18n="laws.kicker">Corpus</p>
          <h1 class="text-4xl md:text-6xl tracking-tight leading-none text-balance" data-i18n="laws.title">All laws</h1>
          <p class="mt-3 text-muted-foreground">
            {total.toLocaleString()} <span data-i18n="laws.norms">norms.</span> <span data-i18n="cmd.title">Search</span> <kbd class="inline-flex items-center px-1.5 py-0.5 text-xs rounded bg-muted border border-border font-id">⌘&nbsp;K</kbd> <span data-i18n="laws.useSearch">to search by title or ID.</span>
          </p>
        </div>
        <div class="flex items-center gap-2 text-xs text-muted-foreground">
          <FilterIcon className="size-3.5" />
          <span data-i18n="laws.sorted">Sorted by publication date (descending)</span>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-12">
      {initial.length === 0 ? (
        <Empty>
          <EmptyHeader>
            <EmptyMedia variant="icon">
              <SearchIcon />
            </EmptyMedia>
            <EmptyTitle><span data-i18n="laws.emptyTitle">No norms in the corpus yet</span></EmptyTitle>
            <EmptyDescription>
              <span data-i18n="laws.emptyDesc">The corpus is being built. Check back soon.</span>
            </EmptyDescription>
          </EmptyHeader>
        </Empty>
      ) : (
        <>
          <ul class="divide-y divide-border/60 border border-border/60 rounded-xl overflow-hidden bg-card">
            {initial.map((n) => {
              const status = STATUS_LABELS[n.status] ?? STATUS_LABELS.in_force;
              const statusKey = STATUS_LABELS[n.status] ? n.status : "in_force";
              return (
                <li>
                  <a
                    href={`/laws/${n.id}`}
                    class="group flex items-start gap-4 px-5 py-4 transition-colors hover:bg-accent/50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-ring"
                  >
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2 mb-1.5 flex-wrap">
                        <Badge variant="outline" className="font-id text-xs">{n.identifier}</Badge>
                        <Badge variant="secondary" className="text-xs"><span data-i18n={`rank.${n.rank}`}>{RANK_LABELS_EN[n.rank] ?? n.rank}</span></Badge>
                        {n.jurisdiction !== "pe" && (
                          <Badge variant="outline" className="text-xs">
                            {jurisdictionLabels[n.jurisdiction] ?? n.jurisdiction}
                          </Badge>
                        )}
                        <span class={`text-xs flex items-center gap-1 ${status.cls}`}>
                          <span class="size-1.5 rounded-full bg-current" />
                          <span data-i18n={`status.${statusKey}`}>{status.label}</span>
                        </span>
                      </div>
                      <p class="text-sm leading-snug group-hover:text-foreground">{n.title.replace(/\.{2,}$/, "…")}</p>
                    </div>
                    <div class="flex shrink-0 items-center gap-2 mt-1">
                      <time datetime={n.publication_date} class="text-xs text-muted-foreground font-id">
                        {n.publication_date}
                      </time>
                      <ArrowRightIcon className="size-4 text-muted-foreground -translate-x-1 opacity-0 transition-[transform,opacity] duration-200 group-hover:translate-x-0 group-hover:opacity-100" />
                    </div>
                  </a>
                </li>
              );
            })}
          </ul>

          {total > PAGE_SIZE && (
            <div class="mt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-muted-foreground">
              <p><span data-i18n="laws.showing">Showing</span> {PAGE_SIZE} <span data-i18n="laws.of">of</span> {total.toLocaleString()} <span data-i18n="laws.norms">norms.</span></p>
              <p><span data-i18n="cmd.title">Search</span> <kbd class="inline-flex items-center px-1.5 py-0.5 text-xs rounded bg-muted border border-border font-id">⌘&nbsp;K</kbd> <span data-i18n="laws.useSearchRest">to search the rest.</span></p>
            </div>
          )}
        </>
      )}
    </div>
  </section>
</Layout>
