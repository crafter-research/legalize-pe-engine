---
import { readFileSync } from "node:fs";
import { join } from "node:path";
import { Badge } from "@/components/ui/badge";
import { buttonVariants } from "@/components/ui/button";
import Layout from "@/layouts/Layout.astro";
import {
  collectAllNormFiles,
  jurisdictionLabels,
  normUniqueId,
  parseFrontmatter,
} from "@/lib/laws";
import { ArrowRightIcon, CodeIcon, GitCommitIcon, GitForkIcon, ScrollTextIcon } from "lucide-react";

const files = collectAllNormFiles();
const stats = {
  total: files.length,
  national: files.filter((f) => f.absDir.endsWith("/pe")).length,
  reformasConst: files.filter((f) => f.relativePath.startsWith("reformas-constitucionales/"))
    .length,
  regional: files.filter((f) => !f.absDir.endsWith("/pe")).length,
  jurisdictionsCovered: new Set(
    files.filter((f) => !f.absDir.endsWith("/pe")).map((f) => f.absDir.split("/").pop()),
  ).size,
};

type Norm = {
  identifier: string;
  id: string;
  title: string;
  rank: string;
  publication_date: string;
  jurisdiction: string;
};
const MAX_Y = new Date().getFullYear() + 1;
const recent: Norm[] = [];
for (const { absDir, relativePath } of files) {
  try {
    const raw = readFileSync(join(absDir, relativePath), "utf-8");
    const { meta } = parseFrontmatter(raw);
    if (!meta.title || !meta.identifier || !meta.publication_date) continue;
    const y = Number(meta.publication_date.slice(0, 4));
    if (y < 1900 || y > MAX_Y) continue;
    recent.push({
      identifier: meta.identifier,
      id: normUniqueId(`${absDir.split("/").pop() ?? ""}/${relativePath}`),
      title: meta.title,
      rank: meta.rank ?? "",
      publication_date: meta.publication_date,
      jurisdiction: meta.jurisdiction ?? "pe",
    });
  } catch {
    /* skip */
  }
}
recent.sort((a, b) => b.publication_date.localeCompare(a.publication_date));
const recentTop = recent.slice(0, 6);

const RANK_LABELS_EN: Record<string, string> = {
  constitucion: "Constitution",
  ley: "Law",
  decreto_legislativo: "Legislative Decree",
  decreto_supremo: "Supreme Decree",
  decreto_de_urgencia: "Urgency Decree",
  decreto_urgencia: "Urgency Decree",
  resolucion_ministerial: "Ministerial Resolution",
  resolucion_suprema: "Supreme Resolution",
  ley_de_reforma_constitucional: "Constitutional Reform",
  ordenanza_regional: "Regional Ordinance",
  ordenanza_municipal: "Municipal Ordinance",
  decreto_regional: "Regional Decree",
  acuerdo_regional: "Regional Agreement",
  acuerdo_de_concejo: "Council Agreement",
  decreto_de_alcaldia: "Mayoral Decree",
};

const stat = [
  {
    label: "National norms",
    labelKey: "home.statNational",
    value: stats.national.toLocaleString(),
    hint: "Laws, DLeg, DS",
    hintKey: "home.statNationalHint",
  },
  {
    label: "Const. reforms",
    labelKey: "home.statReforms",
    value: stats.reformasConst.toLocaleString(),
    hint: "1995 → 2024",
    hintKey: "home.statReformsHint",
  },
  {
    label: "Regional norms",
    labelKey: "home.statRegional",
    value: stats.regional.toLocaleString(),
    hint: "25 GORE + Lima Met",
    hintKey: "home.statRegionalHint",
  },
  {
    label: "Jurisdictions",
    labelKey: "home.statJurisdictions",
    value: `${stats.jurisdictionsCovered}/26`,
    hint: "Sub-national coverage",
    hintKey: "home.statJurisdictionsHint",
  },
];

const features = [
  {
    Icon: GitCommitIcon,
    title: "Every reform is a commit",
    titleKey: "home.feat1Title",
    body: "The 1993 Constitution has 32 commits over the same file: one for the original text and one per amendment, dated correctly.",
    bodyKey: "home.feat1Body",
  },
  {
    Icon: ScrollTextIcon,
    title: "Plain markdown, plain YAML",
    titleKey: "home.feat2Title",
    body: "No proprietary format. Every norm is a single .md file with eight standard frontmatter fields you can parse in any language.",
    bodyKey: "home.feat2Body",
  },
  {
    Icon: CodeIcon,
    title: "For agents and humans",
    titleKey: "home.feat3Title",
    body: "Use it as LLM context, as research input, as a CLI argument, or browse it here. Public domain (DLeg 822 Art. 9).",
    bodyKey: "home.feat3Body",
  },
];
---

<Layout title="Legalize PE" description="Peruvian legislation as a git repository. Every law a file, every reform a commit.">
  <section class="border-b border-border/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 pt-16 pb-20 lg:pt-24 lg:pb-28">
      <div class="max-w-3xl">
        <Badge variant="outline" className="mb-6 gap-1.5">
          <span class="size-1.5 rounded-full bg-status-in-force"></span>
          <span data-i18n="home.badge">Pre-1.0 · Community-maintained</span>
        </Badge>
        <h1 class="text-5xl md:text-7xl tracking-tighter leading-[0.95] text-balance" data-i18n="home.hero">
          Peruvian law,<br />
          <span class="text-primary">as a git repo.</span>
        </h1>
        <p class="mt-6 max-w-2xl text-lg text-muted-foreground leading-relaxed">
          {stats.total.toLocaleString()} <span data-i18n="home.heroSub">legal norms as Markdown files. Every reform is a commit
          with the real publication date. Clone it, grep it, diff it, build on it.</span>
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/laws" class={buttonVariants({ size: "lg", className: "group gap-2" })}>
            <span data-i18n="home.browseLaws">Browse laws</span> <ArrowRightIcon className="size-4 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
          <a
            href="https://github.com/crafter-research/legalize-pe"
            class={buttonVariants({ variant: "outline", size: "lg", className: "gap-2" })}
          >
            <GitForkIcon className="size-4" /> <span data-i18n="home.cloneGithub">Clone on GitHub</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-border/60 bg-card/30">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-12 lg:py-16">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-px bg-border/60 rounded-xl overflow-hidden">
        {stat.map((s) => (
          <div class="bg-card p-6 lg:p-8 flex flex-col gap-1.5">
            <p class="text-xs text-muted-foreground uppercase tracking-wider" data-i18n={s.labelKey}>{s.label}</p>
            <p class="text-4xl md:text-5xl tracking-tight tabular-nums">{s.value}</p>
            <p class="text-xs text-muted-foreground" data-i18n={s.hintKey}>{s.hint}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="border-b border-border/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-16 lg:py-24">
      <div class="max-w-2xl mb-12">
        <p class="text-sm font-medium text-primary uppercase tracking-widest mb-3" data-i18n="home.whatYouGet">What you get</p>
        <h2 class="text-3xl md:text-5xl tracking-tight leading-tight text-balance" data-i18n="home.whatYouGetTitle">
          Legal infrastructure that&apos;s actually <em class="italic text-primary">accessible.</em>
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-px bg-border/60 rounded-xl overflow-hidden">
        {features.map(({ Icon, title, titleKey, body, bodyKey }) => (
          <div class="bg-card p-8 flex flex-col gap-3">
            <Icon className="size-6 text-primary" />
            <h3 class="text-2xl tracking-tight leading-tight" data-i18n={titleKey}>{title}</h3>
            <p class="text-sm text-muted-foreground leading-relaxed" data-i18n={bodyKey}>{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {recentTop.length > 0 && (
    <section class="border-b border-border/60">
      <div class="mx-auto max-w-6xl px-4 sm:px-6 py-16 lg:py-24">
        <div class="flex items-end justify-between mb-8">
          <div>
            <p class="text-sm font-medium text-primary uppercase tracking-widest mb-3" data-i18n="home.recent">Recent</p>
            <h2 class="text-3xl md:text-4xl tracking-tight text-balance" data-i18n="home.recentTitle">Latest norms in the corpus</h2>
          </div>
          <a href="/laws" class="group hidden md:inline-flex items-center gap-1.5 rounded-sm text-sm text-muted-foreground transition-colors hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
            <span data-i18n="home.allLaws">All laws</span> <ArrowRightIcon className="size-3.5 transition-transform duration-200 group-hover:translate-x-0.5" />
          </a>
        </div>

        <ul class="divide-y divide-border/60 border border-border/60 rounded-xl overflow-hidden bg-card">
          {recentTop.map((n) => (
            <li>
              <a
                href={`/laws/${n.id}`}
                class="group flex items-start gap-4 px-5 py-4 transition-colors hover:bg-accent/50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-ring"
              >
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1 flex-wrap">
                    <Badge variant="outline" className="font-id text-xs">{n.identifier}</Badge>
                    <Badge variant="secondary" className="text-xs"><span data-i18n={`rank.${n.rank}`}>{RANK_LABELS_EN[n.rank] ?? n.rank}</span></Badge>
                    {n.jurisdiction !== "pe" && (
                      <Badge variant="outline" className="text-xs">{jurisdictionLabels[n.jurisdiction] ?? n.jurisdiction}</Badge>
                    )}
                  </div>
                  <p class="text-sm leading-snug group-hover:text-foreground">{n.title.replace(/\.{2,}$/, "…")}</p>
                </div>
                <div class="flex items-center gap-2 shrink-0">
                  <time datetime={n.publication_date} class="text-xs text-muted-foreground font-id">
                    {n.publication_date}
                  </time>
                  <ArrowRightIcon className="size-4 text-muted-foreground -translate-x-1 opacity-0 transition-[transform,opacity] duration-200 group-hover:translate-x-0 group-hover:opacity-100" />
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <section>
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-16 lg:py-24">
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div>
          <p class="text-sm font-medium text-primary uppercase tracking-widest mb-3" data-i18n="home.federation">Federation</p>
          <h2 class="text-3xl md:text-5xl tracking-tight leading-tight text-balance" data-i18n="home.federationTitle">
            Part of <em class="italic">legalize.dev</em>
          </h2>
          <p class="mt-4 text-muted-foreground leading-relaxed" data-i18n="home.federationBody">
            Same spec, same commit conventions, same git-native workflow as Spain, Portugal,
            Italy, Korea, and 30+ other countries. Community-maintained by Crafter Research.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="https://legalize.dev" class={buttonVariants({ variant: "outline", size: "sm" })}>legalize.dev →</a>
            <a href="/about" data-i18n="home.whyExists" class={buttonVariants({ variant: "ghost", size: "sm" })}>Why this exists</a>
          </div>
        </div>

        <div translate="no" class="bg-card border border-border/60 rounded-xl p-6 font-id text-xs leading-relaxed overflow-x-auto">
          <p class="text-muted-foreground mb-3" data-i18n="home.apiComment"># Clone, grep, diff. That&apos;s the API.</p>
          <p><span class="text-muted-foreground">$</span> git clone https://github.com/crafter-research/legalize-pe</p>
          <p><span class="text-muted-foreground">$</span> grep -A 20 "Artículo 191" pe/CON-1993.md</p>
          <p><span class="text-muted-foreground">$</span> git log --oneline pe/CON-1993.md</p>
          <p class="text-muted-foreground mt-1">8792882 2024-12-11 [reform] art. 89</p>
          <p class="text-muted-foreground">6d8e91d 2024-12-11 [reform] arts. 7, 23</p>
          <p class="text-muted-foreground">2d46dcc 2024-10-29 [reform] art. 49</p>
          <p class="text-muted-foreground">...</p>
          <p class="text-muted-foreground">6d06441 1993-12-30 [bootstrap]</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
