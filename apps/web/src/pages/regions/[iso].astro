---
import { readFileSync } from "node:fs";
import { join } from "node:path";
import { Badge } from "@/components/ui/badge";
import Layout from "@/layouts/Layout.astro";
import {
  collectAllNormFiles,
  jurisdictionLabels,
  normUniqueId,
  parseFrontmatter,
} from "@/lib/laws";
import { ArrowRightIcon } from "lucide-react";

export async function getStaticPaths() {
  const seen = new Set<string>();
  for (const { absDir } of collectAllNormFiles()) {
    const name = absDir.split("/").pop() ?? "";
    if (name.startsWith("pe-")) seen.add(name);
  }
  return [...seen].map((iso) => ({ params: { iso } }));
}

const { iso } = Astro.params;

type Norm = {
  identifier: string;
  id: string;
  title: string;
  rank: string;
  publication_date: string;
};
const norms: Norm[] = [];
for (const { absDir, relativePath } of collectAllNormFiles()) {
  if ((absDir.split("/").pop() ?? "") !== iso) continue;
  try {
    const raw = readFileSync(join(absDir, relativePath), "utf-8");
    const { meta } = parseFrontmatter(raw);
    if (!meta.title || !meta.identifier) continue;
    norms.push({
      identifier: meta.identifier,
      id: normUniqueId(`${absDir.split("/").pop() ?? ""}/${relativePath}`),
      title: meta.title,
      rank: meta.rank ?? "",
      publication_date: meta.publication_date ?? "",
    });
  } catch {
    /* skip */
  }
}
norms.sort((a, b) => b.publication_date.localeCompare(a.publication_date));

const name = jurisdictionLabels[iso ?? ""] ?? iso;
---

<Layout title={`${name} · Legalize PE`} description={`${norms.length} norms from ${name}`}>
  <div class="mx-auto max-w-6xl px-4 sm:px-6 py-8 lg:py-12">
    <nav class="mb-8 flex items-center gap-2 text-sm text-muted-foreground" aria-label="Breadcrumb">
      <a href="/" class="rounded-sm hover:text-foreground transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" data-i18n="nav.home">Home</a>
      <span aria-hidden>/</span>
      <a href="/regions" class="rounded-sm hover:text-foreground transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" data-i18n="nav.regions">Regions</a>
      <span aria-hidden>/</span>
      <span class="text-foreground">{name}</span>
    </nav>

    <header class="mb-10 pb-8 border-b border-border/60">
      <div class="flex items-center gap-2 mb-3">
        <Badge variant="outline" className="font-id">{iso}</Badge>
        <span class="text-xs text-muted-foreground">{norms.length} <span data-i18n={norms.length === 1 ? "region.normOne" : "region.normMany"}>{norms.length === 1 ? "norm" : "norms"}</span></span>
      </div>
      <h1 class="text-4xl md:text-6xl tracking-tight leading-none text-balance">{name}</h1>
    </header>

    {norms.length === 0 ? (
      <p class="text-muted-foreground" data-i18n="region.empty">No norms yet. Coming in V2.</p>
    ) : (
      <ul class="divide-y divide-border/60 border border-border/60 rounded-xl overflow-hidden bg-card">
        {norms.map((n) => (
          <li>
            <a
              href={`/laws/${n.id}`}
              class="group flex items-start gap-4 px-5 py-4 transition-colors hover:bg-accent/50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-ring"
            >
              <div class="flex-1 min-w-0">
                <Badge variant="outline" className="font-id text-xs mb-1.5">{n.identifier}</Badge>
                <p class="text-sm leading-snug group-hover:text-foreground">{n.title.replace(/\.{2,}$/, "…")}</p>
              </div>
              <div class="flex shrink-0 items-center gap-2 mt-1">
                {n.publication_date && (
                  <time datetime={n.publication_date} class="text-xs text-muted-foreground font-id">
                    {n.publication_date}
                  </time>
                )}
                <ArrowRightIcon className="size-4 text-muted-foreground -translate-x-1 opacity-0 transition-[transform,opacity] duration-200 group-hover:translate-x-0 group-hover:opacity-100" />
              </div>
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</Layout>
