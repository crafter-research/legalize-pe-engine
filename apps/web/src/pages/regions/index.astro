---
import { Badge } from "@/components/ui/badge";
import Layout from "@/layouts/Layout.astro";
import { REGIONAL_JURISDICTIONS, collectAllNormFiles } from "@/lib/laws";
import { ArrowRightIcon } from "lucide-react";

// Count norms per jurisdiction directly from the directory name (fast — no frontmatter parse).
const counts: Record<string, number> = {};
for (const { absDir } of collectAllNormFiles()) {
  const dir = absDir.split("/").pop() ?? "";
  if (!dir.startsWith("pe-")) continue;
  counts[dir] = (counts[dir] ?? 0) + 1;
}

const rows = REGIONAL_JURISDICTIONS.map((j) => ({
  ...j,
  count: counts[j.iso] ?? 0,
})).sort((a, b) => b.count - a.count);

const covered = rows.filter((r) => r.count > 0).length;
const totalRegional = rows.reduce((s, r) => s + r.count, 0);
const fmt = (n: number) => n.toLocaleString("es-PE");
---

<Layout
  title="Regional jurisdictions · Legalize PE"
  description={`${fmt(totalRegional)} regional norms across ${covered} jurisdictions (25 regional governments + Lima Metropolitana).`}
>
  <section class="border-b border-border/60">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-12 lg:py-16">
      <nav class="mb-6 flex items-center gap-2 text-sm text-muted-foreground" aria-label="Breadcrumb">
        <a href="/" class="rounded-sm hover:text-foreground transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring" data-i18n="nav.home">Home</a>
        <span aria-hidden>/</span>
        <span class="text-foreground" data-i18n="nav.regions">Regions</span>
      </nav>
      <p class="text-sm font-medium text-primary uppercase tracking-widest mb-3" data-i18n="regions.kicker">Sub-national tier</p>
      <h1 class="text-4xl md:text-6xl tracking-tight leading-none text-balance" data-i18n="regions.title">Regional jurisdictions</h1>
      <p class="mt-4 max-w-2xl text-muted-foreground leading-relaxed" data-i18n="regions.intro">
        The first cohesive sub-national legal corpus for a Global South country —
        regional-government coverage no other Peruvian source offers.
      </p>
      <div class="mt-8 flex flex-wrap gap-x-10 gap-y-4">
        <div>
          <div class="text-3xl tabular-nums tracking-tight">{fmt(totalRegional)}</div>
          <div class="text-xs text-muted-foreground uppercase tracking-wide" data-i18n="regions.statRegional">regional norms</div>
        </div>
        <div>
          <div class="text-3xl tabular-nums tracking-tight">{covered}<span class="text-muted-foreground text-xl">/{rows.length}</span></div>
          <div class="text-xs text-muted-foreground uppercase tracking-wide" data-i18n="regions.statJurisdictions">jurisdictions</div>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="mx-auto max-w-6xl px-4 sm:px-6 py-12">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {rows.map((j) => {
          const isCovered = j.count > 0;
          return (
            <a
              href={isCovered ? `/regions/${j.iso}` : undefined}
              aria-disabled={!isCovered}
              class:list={[
                "block border border-border/60 rounded-xl p-5 bg-card transition-[color,border-color,box-shadow] duration-200",
                isCovered
                  ? "group hover:border-primary/40 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
                  : "opacity-40 cursor-not-allowed",
              ]}
            >
              <div class="flex items-start justify-between gap-3 mb-3">
                <h3 class="text-xl tracking-tight leading-tight">{j.name}</h3>
                {isCovered && (
                  <ArrowRightIcon className="size-4 shrink-0 mt-1 text-muted-foreground transition-[color,transform] duration-200 group-hover:text-primary group-hover:translate-x-0.5" />
                )}
              </div>
              <div class="flex items-center justify-between gap-2 text-xs">
                <Badge variant="outline" className="font-id">{j.iso}</Badge>
                {isCovered ? (
                  <span class="tabular-nums text-muted-foreground">{fmt(j.count)} <span data-i18n="regions.normsSuffix">norms</span></span>
                ) : (
                  <span class="text-muted-foreground" data-i18n="regions.pending">Pending</span>
                )}
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</Layout>
